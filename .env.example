# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub

# Your MetaMask wallet private key (export from MetaMask > Account Details > Export Private Key)
POLYMARKET_PRIVATE_KEY=0x...

# Your Polygon wallet address (the 0x address shown in MetaMask)
POLYMARKET_WALLET_ADDRESS=0x...

# Chain ID for Polygon mainnet - do not change
POLYMARKET_CHAIN_ID=137

# Trading guardrails
POLYMARKET_MAX_TRADE_EUR=20
POLYMARKET_MAX_OPEN_POSITIONS=5
POLYMARKET_DAILY_LOSS_CAP_EUR=25
